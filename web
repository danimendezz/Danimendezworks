<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Daniela Méndez · Comunicación Digital</title>
<meta name="description" content="Portfolio de Daniela Méndez, estudiante de Comunicación Digital en la UVa Segovia.">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --lime:#E2FC2D;
  --olive:#435B3C;
  --olive-light:#5a7a52;
  --cream:#F7F7F2;
  --white:#ffffff;
  --dark:#1a1a1a;
  --gray:#888888;
  --border:#eeeeee;
}
html{scroll-behavior:smooth;}
body{font-family:'Inter',sans-serif;background:var(--white);color:var(--dark);overflow-x:hidden;}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;justify-content:space-between;align-items:center;
  padding:1.2rem 4rem;
  background:rgba(255,255,255,0.92);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
  transition:padding 0.3s;
}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:2px;color:var(--olive);text-decoration:none;}
.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{text-decoration:none;color:var(--dark);font-size:0.82rem;font-weight:500;letter-spacing:1px;text-transform:uppercase;transition:color 0.2s;}
.nav-links a:hover{color:var(--olive);}
.nav-toggle{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;}
.nav-toggle span{width:22px;height:2px;background:var(--dark);border-radius:2px;transition:all 0.3s;}

/* ── HERO ── */
.hero{
  min-height:100vh;
  display:flex;align-items:center;
  padding:0 4rem;
  background:var(--white);
  position:relative;overflow:hidden;
}
.hero-blob{
  position:absolute;right:-140px;top:50%;transform:translateY(-50%);
  width:560px;height:560px;
  background:var(--lime);
  border-radius:60% 40% 55% 45% / 45% 55% 45% 55%;
  animation:morph 8s ease-in-out infinite;
}
.hero-blob-2{
  position:absolute;right:-80px;top:50%;transform:translateY(-50%);
  width:360px;height:360px;
  background:var(--olive);opacity:0.2;
  border-radius:40% 60% 50% 50% / 50% 40% 60% 50%;
  animation:morph 11s ease-in-out infinite reverse;
}
@keyframes morph{
  0%{border-radius:60% 40% 55% 45% / 45% 55% 45% 55%;}
  33%{border-radius:40% 60% 45% 55% / 55% 45% 55% 45%;}
  66%{border-radius:55% 45% 65% 35% / 35% 65% 35% 65%;}
  100%{border-radius:60% 40% 55% 45% / 45% 55% 45% 55%;}
}
.hero-content{position:relative;z-index:2;max-width:600px;}
.hero-tag{
  display:inline-block;
  background:var(--lime);color:var(--olive);
  font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  padding:0.4rem 1rem;border-radius:2rem;
  margin-bottom:1.5rem;
}
.hero-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(4rem,9vw,7.5rem);
  line-height:0.92;letter-spacing:2px;
  color:var(--dark);margin-bottom:1.2rem;
}
.hero-title span{color:var(--olive);}
.hero-sub{font-size:1rem;color:#555;line-height:1.75;margin-bottom:2.2rem;max-width:420px;}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap;}
.btn-primary{
  display:inline-flex;align-items:center;gap:0.5rem;
  background:var(--olive);color:var(--white);
  padding:0.9rem 2rem;border-radius:2rem;
  text-decoration:none;font-weight:600;font-size:0.88rem;
  transition:all 0.3s;
}
.btn-primary:hover{background:var(--lime);color:var(--olive);transform:translateY(-2px);}
.btn-secondary{
  display:inline-flex;align-items:center;gap:0.5rem;
  background:transparent;color:var(--olive);
  border:1.5px solid var(--olive);
  padding:0.9rem 2rem;border-radius:2rem;
  text-decoration:none;font-weight:600;font-size:0.88rem;
  transition:all 0.3s;
}
.btn-secondary:hover{background:var(--olive);color:var(--white);}
.hero-scroll{
  position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:0.5rem;
  color:var(--gray);font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;
}
.scroll-line{width:1px;height:56px;background:linear-gradient(to bottom,var(--olive),transparent);animation:scrollpulse 2s ease-in-out infinite;}
@keyframes scrollpulse{0%,100%{opacity:1;}50%{opacity:0.3;}}

/* ── ABOUT ── */
.about{
  padding:8rem 4rem;
  background:var(--cream);
  display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;
}
.section-eyebrow{font-size:0.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--olive);font-weight:700;margin-bottom:1rem;}
.about-title{font-family:'Bebas Neue',sans-serif;font-size:3.8rem;line-height:0.95;color:var(--dark);margin-bottom:1.8rem;}
.about-text{color:#555;line-height:1.85;font-size:0.95rem;margin-bottom:1.5rem;}
.about-detail{display:flex;gap:0.5rem;align-items:center;font-size:0.85rem;color:var(--olive);font-weight:500;}
.about-visual{position:relative;}
.about-svg{width:100%;max-width:440px;}

/* ── SKILLS ── */
.skills{padding:8rem 4rem;background:var(--white);}
.section-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:4rem;flex-wrap:wrap;gap:1rem;}
.section-title{font-family:'Bebas Neue',sans-serif;font-size:3.2rem;color:var(--dark);line-height:1;}
.section-note{font-size:0.85rem;color:var(--gray);max-width:180px;text-align:right;}
.skills-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;}
.skill-card{
  padding:1.6rem 2rem;
  border:1.5px solid var(--border);border-radius:1rem;
  transition:all 0.3s;cursor:default;
}
.skill-card:hover{border-color:var(--lime);transform:translateY(-4px);}
.skill-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;}
.skill-name{font-weight:600;font-size:0.95rem;}
.skill-pct{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--olive);}
.skill-bar{height:4px;background:#eee;border-radius:2px;overflow:hidden;}
.skill-fill{height:100%;background:var(--lime);border-radius:2px;width:0;transition:width 1.4s cubic-bezier(.4,0,.2,1);}

/* ── REDES / PHONES ── */
.redes{padding:8rem 0 8rem 4rem;background:var(--cream);overflow:hidden;}
.redes-header{margin-bottom:3.5rem;padding-right:4rem;}
.redes-sub{color:#666;font-size:0.9rem;margin-top:0.6rem;}
.phones-track-wrapper{overflow-x:auto;overflow-y:visible;cursor:grab;user-select:none;padding-bottom:1rem;scrollbar-width:none;}
.phones-track-wrapper::-webkit-scrollbar{display:none;}
.phones-track-wrapper.dragging{cursor:grabbing;}
.phones-track{display:flex;gap:2.5rem;width:max-content;padding:2rem 4rem 3rem 0.5rem;}
.phone-wrap{
  flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:0.8rem;
  transition:transform 0.3s;
}
.phone-wrap:hover{transform:translateY(-10px) scale(1.04);}
.phone-frame{
  width:165px;height:310px;
  background:#111;border-radius:30px;border:6px solid #1e1e1e;
  position:relative;overflow:hidden;
  box-shadow:0 16px 48px rgba(0,0,0,0.2);
  cursor:pointer;
}
.phone-notch{
  position:absolute;top:0;left:50%;transform:translateX(-50%);
  width:56px;height:14px;
  background:#111;border-radius:0 0 10px 10px;z-index:10;
}
.phone-screen{width:100%;height:100%;overflow:hidden;position:relative;}
.phone-scroll-inner{width:100%;animation:phoneScroll 7s linear infinite;}
.phone-wrap:hover .phone-scroll-inner{animation-play-state:paused;}
@keyframes phoneScroll{0%{transform:translateY(0);}100%{transform:translateY(-50%);}  }
.phone-label{font-size:0.8rem;font-weight:700;color:var(--olive);letter-spacing:0.5px;}
.phone-followers{font-size:0.7rem;color:var(--gray);}
.phone-hint{font-size:0.68rem;color:#bbb;letter-spacing:1px;text-transform:uppercase;}
.scroll-hint{text-align:left;margin-top:0.5rem;padding-left:0.5rem;font-size:0.75rem;color:#bbb;letter-spacing:1px;}

/* ── PORTFOLIO ── */
.portfolio{padding:8rem 4rem;background:var(--white);}
.portfolio-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:4rem;}
.port-card{
  border-radius:1.2rem;overflow:hidden;
  background:var(--white);border:1.5px solid var(--border);
  transition:all 0.35s;cursor:pointer;text-decoration:none;
}
.port-card:hover{transform:translateY(-8px);border-color:var(--lime);box-shadow:0 16px 48px rgba(67,91,60,0.1);}
.port-thumb{
  height:170px;display:flex;align-items:center;justify-content:center;
  font-family:'Bebas Neue',sans-serif;font-size:3.2rem;letter-spacing:3px;
}
.port-thumb.c1{background:var(--lime);color:var(--olive);}
.port-thumb.c2{background:var(--olive);color:var(--lime);}
.port-thumb.c3{background:#f0f0e8;color:var(--olive);}
.port-body{padding:1.3rem 1.5rem;}
.port-tag{font-size:0.68rem;letter-spacing:2px;text-transform:uppercase;color:var(--olive);font-weight:700;margin-bottom:0.4rem;}
.port-name{font-weight:600;font-size:0.95rem;color:var(--dark);}

/* ── CONTACT ── */
.contact{
  padding:8rem 4rem;
  background:var(--olive);
  position:relative;overflow:hidden;
}
.contact-blob{
  position:absolute;right:-100px;bottom:-100px;
  width:400px;height:400px;
  background:var(--lime);opacity:0.18;
  border-radius:60% 40% 55% 45% / 45% 55% 45% 55%;
  animation:morph 10s ease-in-out infinite;
}
.contact-blob-2{
  position:absolute;left:-80px;top:-80px;
  width:280px;height:280px;
  background:var(--lime);opacity:0.1;
  border-radius:50%;
}
.contact-inner{position:relative;z-index:2;max-width:600px;}
.contact-eyebrow{font-size:0.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--lime);font-weight:700;margin-bottom:1rem;}
.contact-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(3rem,7vw,5.5rem);
  color:var(--white);line-height:0.95;margin-bottom:1.2rem;
}
.contact-title span{color:var(--lime);}
.contact-sub{color:rgba(255,255,255,0.6);font-size:0.95rem;margin-bottom:2.5rem;line-height:1.75;max-width:380px;}
.contact-row{display:flex;gap:1rem;flex-wrap:wrap;}
.btn-lime{
  display:inline-flex;align-items:center;gap:0.5rem;
  background:var(--lime);color:var(--olive);
  padding:0.9rem 1.8rem;border-radius:2rem;
  text-decoration:none;font-weight:700;font-size:0.85rem;
  transition:all 0.3s;
}
.btn-lime:hover{background:var(--white);color:var(--olive);}
.btn-ghost{
  display:inline-flex;align-items:center;gap:0.5rem;
  background:transparent;color:var(--white);
  border:1.5px solid rgba(255,255,255,0.35);
  padding:0.9rem 1.8rem;border-radius:2rem;
  text-decoration:none;font-weight:600;font-size:0.85rem;
  transition:all 0.3s;
}
.btn-ghost:hover{border-color:var(--lime);color:var(--lime);}

/* ── FOOTER ── */
footer{
  background:var(--white);
  padding:1.8rem 4rem;
  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;
  border-top:1px solid var(--border);
}
.footer-logo{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:var(--olive);letter-spacing:2px;}
.footer-text{font-size:0.78rem;color:var(--gray);}

/* ── DRAWER ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:200;opacity:0;pointer-events:none;transition:opacity 0.3s;}
.overlay.open{opacity:1;pointer-events:all;}
.drawer{
  position:fixed;right:0;top:0;height:100%;width:380px;
  background:var(--white);z-index:300;
  transform:translateX(100%);transition:transform 0.4s cubic-bezier(.4,0,.2,1);
  overflow-y:auto;box-shadow:-8px 0 48px rgba(0,0,0,0.12);
}
.drawer.open{transform:translateX(0);}
.drawer-close{
  position:absolute;top:1.2rem;right:1.2rem;
  background:none;border:none;font-size:1.4rem;
  cursor:pointer;color:var(--gray);line-height:1;
  width:36px;height:36px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  transition:background 0.2s;
}
.drawer-close:hover{background:var(--cream);}
.drawer-thumb-ph{
  width:100%;height:200px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Bebas Neue',sans-serif;font-size:3.5rem;letter-spacing:3px;
}
.drawer-body{padding:1.8rem;}
.drawer-tag{
  display:inline-block;
  background:var(--lime);color:var(--olive);
  font-size:0.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  padding:0.3rem 0.9rem;border-radius:2rem;margin-bottom:1rem;
}
.drawer-name{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;color:var(--dark);line-height:1;margin-bottom:0.3rem;}
.drawer-handle{font-size:0.82rem;color:var(--olive);font-weight:600;margin-bottom:1rem;}
.drawer-desc{font-size:0.88rem;color:#555;line-height:1.8;margin-bottom:1.5rem;}
.drawer-stats{display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;margin-bottom:1.5rem;}
.d-stat{background:var(--cream);border-radius:0.75rem;padding:1rem;text-align:center;}
.d-stat-n{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;}
.d-stat-l{font-size:0.68rem;color:var(--gray);text-transform:uppercase;letter-spacing:1px;margin-top:2px;}
.drawer-work-title{font-size:0.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--olive);margin-bottom:0.8rem;}
.drawer-work-list{list-style:none;display:flex;flex-direction:column;gap:0.5rem;}
.drawer-work-list li{font-size:0.85rem;color:#444;display:flex;align-items:flex-start;gap:0.6rem;}
.drawer-work-list li::before{content:"✦";color:var(--lime);font-size:0.6rem;margin-top:4px;flex-shrink:0;}
.drawer-link{
  display:inline-flex;align-items:center;gap:0.5rem;
  margin-top:1.5rem;background:var(--olive);color:var(--white);
  padding:0.8rem 1.5rem;border-radius:2rem;
  font-size:0.82rem;font-weight:600;text-decoration:none;
  transition:all 0.2s;
}
.drawer-link:hover{background:var(--lime);color:var(--olive);}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  nav{padding:1rem 2rem;}
  .nav-links{display:none;}
  .nav-toggle{display:flex;}
  .hero{padding:6rem 2rem 4rem;}
  .hero-blob{width:300px;height:300px;right:-80px;}
  .hero-blob-2{width:200px;height:200px;right:-40px;}
  .about{grid-template-columns:1fr;padding:5rem 2rem;gap:3rem;}
  .about-visual{display:none;}
  .skills{padding:5rem 2rem;}
  .skills-grid{grid-template-columns:1fr;}
  .redes{padding:5rem 0 5rem 2rem;}
  .redes-header{padding-right:2rem;}
  .portfolio{padding:5rem 2rem;}
  .portfolio-grid{grid-template-columns:repeat(2,1fr);}
  .contact{padding:5rem 2rem;}
  footer{padding:1.5rem 2rem;}
  .drawer{width:100%;max-width:400px;}
}
@media(max-width:560px){
  .portfolio-grid{grid-template-columns:1fr;}
}
@media(prefers-reduced-motion:reduce){
  .hero-blob,.hero-blob-2,.contact-blob{animation:none;}
  .phone-scroll-inner{animation:none;}
  .skill-fill{transition:none;}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">DM</a>
  <ul class="nav-links">
    <li><a href="#about">Sobre mí</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#redes">Redes</a></li>
    <li><a href="#portfolio">Portafolio</a></li>
    <li><a href="#contact">Contacto</a></li>
  </ul>
  <div class="nav-toggle" onclick="toggleMenu()" aria-label="Menú">
    <span></span><span></span><span></span>
  </div>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-blob" aria-hidden="true"></div>
  <div class="hero-blob-2" aria-hidden="true"></div>
  <div class="hero-content">
    <div class="hero-tag">✦ Comunicación Digital · Segovia</div>
    <h1 class="hero-title">DANIELA<br><span>MÉNDEZ</span></h1>
    <p class="hero-sub">scroll, arte, té y caos creativo.<br>Estudiante de Comunicación Digital con alma de creadora. Gestión de redes, estrategia de contenido y narrativa audiovisual.</p>
    <div class="hero-actions">
      <a href="#portfolio" class="btn-primary">Ver portafolio →</a>
      <a href="#contact" class="btn-secondary">Hablemos</a>
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span>scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div>
    <p class="section-eyebrow">sobre mí</p>
    <h2 class="about-title">CAOS<br>CREATIVO<br>CON<br>MÉTODO</h2>
    <p class="about-text">Soy Daniela, estudiante de Comunicación Digital en la UVa Campus María Zambrano, Segovia. Me muevo entre el marketing digital, la gestión de redes sociales y la narrativa audiovisual.</p>
    <p class="about-text">Cada proyecto es una oportunidad de contar algo que valga la pena. Trabajo con pasión, con datos y con mucho café.</p>
    <p class="about-detail">✦ &nbsp;Segovia · España</p>
  </div>
  <div class="about-visual" aria-hidden="true">
    <svg class="about-svg" viewBox="0 0 440 300" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,150 C55,60 110,240 165,150 C220,60 275,240 330,150 C385,60 440,180 440,150 L440,300 L0,300 Z" fill="#E2FC2D" opacity="0.55"/>
      <path d="M0,200 C70,120 140,260 210,190 C280,120 350,250 420,180 L440,175 L440,300 L0,300 Z" fill="#435B3C" opacity="0.28"/>
      <circle cx="340" cy="80" r="50" fill="#E2FC2D" opacity="0.35"/>
      <circle cx="100" cy="60" r="30" fill="#435B3C" opacity="0.2"/>
    </svg>
  </div>
</section>

<!-- SKILLS -->
<section class="skills" id="skills">
  <div class="section-head">
    <div>
      <p class="section-eyebrow">herramientas</p>
      <h2 class="section-title">ASÍ TRABAJO</h2>
    </div>
    <p class="section-note">50% pasión · 50% estrés · 100% entrega</p>
  </div>
  <div class="skills-grid">
    <div class="skill-card">
      <div class="skill-top"><span class="skill-name">Notion</span><span class="skill-pct">95%</span></div>
      <div class="skill-bar"><div class="skill-fill" data-w="95"></div></div>
    </div>
    <div class="skill-card">
      <div class="skill-top"><span class="skill-name">Amor al trabajo</span><span class="skill-pct">100%</span></div>
      <div class="skill-bar"><div class="skill-fill" data-w="100"></div></div>
    </div>
    <div class="skill-card">
      <div class="skill-top"><span class="skill-name">Office 365</span><span class="skill-pct">85%</span></div>
      <div class="skill-bar"><div class="skill-fill" data-w="85"></div></div>
    </div>
    <div class="skill-card">
      <div class="skill-top"><span class="skill-name">CapCut</span><span class="skill-pct">70%</span></div>
      <div class="skill-bar"><div class="skill-fill" data-w="70"></div></div>
    </div>
    <div class="skill-card">
      <div class="skill-top"><span class="skill-name">Canva</span><span class="skill-pct">75%</span></div>
      <div class="skill-bar"><div class="skill-fill" data-w="75"></div></div>
    </div>
    <div class="skill-card">
      <div class="skill-top"><span class="skill-name">Inteligencia Artificial</span><span class="skill-pct">50%</span></div>
      <div class="skill-bar"><div class="skill-fill" data-w="50"></div></div>
    </div>
  </div>
</section>

<!-- REDES -->
<section class="redes" id="redes">
  <div class="redes-header">
    <p class="section-eyebrow">gestión de redes sociales</p>
    <h2 class="section-title">CLIENTES &<br>COMUNIDADES</h2>
    <p class="redes-sub">Perfiles de Instagram que gestioné — toca para saber más</p>
  </div>

  <div class="phones-track-wrapper" id="track-wrapper">
    <div class="phones-track" id="phones-track">

      <!-- DILO PROJECT -->
      <div class="phone-wrap">
        <div class="phone-frame" onclick="openDrawer('dilo')" role="button" aria-label="Ver Dilo Project">
          <div class="phone-notch" aria-hidden="true"></div>
          <div class="phone-screen">
